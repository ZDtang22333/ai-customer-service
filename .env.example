# ============================================
# 环境变量配置（复制此文件为 .env 并填入你的配置）
# ============================================

# 小米 MiMo API Key（聊天模型）
# 获取方式：小米 AI 开放平台
OPENAI_API_KEY=你的API密钥

# 小米 MiMo API 地址
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1

# 聊天模型
CHAT_MODEL=mimo-v2.5-pro

# Embedding 模型（本地模型，无需 API）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 文本切分参数
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 检索返回数量
RETRIEVAL_K=3
